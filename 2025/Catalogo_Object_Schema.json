{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://www.univaq.it/f3i/swa/examples/schema_catalogo.json",
  "type": "object",
  "required": [
    "nome",
    "sezioni"
  ],
  "additionalProperties": false,
  "properties": {
    "nome": {
      "type": "string",
      "minLength": 5
    },
    "sezioni": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "codice",
          "nome",
          "prodotti"
        ],
        "additionalProperties": false,
        "properties": {
          "codice": {
            "type": "string"
          },
          "nome": {
            "type": "string",
            "minLength": 2
          },
          "descrizione": {
            "type": "string",
            "maxLength": 500,
            "nullable": true
          },
          "prodotti": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "codice",
                "nome",
                "prezzo",
                "descrizioneBreve"
              ],
              "additionalProperties": false,
              "properties": {
                "codice": {
                  "type": "string",
                  "pattern": "^P-[A-Z0-9]{4,20}$"
                },
                "nome": {
                  "type": "string",
                  "minLength": 2
                },
                "prezzo": {
                  "type": "number",
                  "minimum": 0,
                  "multipleOf": 0.01
                },
                "disponibile": {
                  "type": "boolean",
                  "default": true
                },
                "descrizioneBreve": {
                  "type": "string",
                  "minLength": 5,
                  "maxLength": 300
                },
                "dettagli": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "descrizioneLunga": {
                      "type": "string",
                      "maxLength": 5000
                    },
                    "immagine": {
                      "type": "string",
                      "format": "binary",
                      "description": "File binario dell'immagine (es. JPEG, PNG)"
                    },
                    "ingredienti": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string"
                      }
                    },
                    "allergeni": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "valoriNutrizionali": {
                      "type": "object",
                      "properties": {
                        "kcal": {
                          "type": "number",
                          "minimum": 0
                        },
                        "grassi": {
                          "type": "number",
                          "minimum": 0
                        },
                        "carboidrati": {
                          "type": "number",
                          "minimum": 0
                        },
                        "proteine": {
                          "type": "number",
                          "minimum": 0
                        }
                      }
                    },
                    "modalitaConservazione": {
                      "type": "string"
                    },
                    "modalitaPreparazione": {
                      "type": "string"
                    },
                    "origine": {
                      "type": "string"
                    },
                    "etichette": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}